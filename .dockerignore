.output
dist

# Local database – never bake into the image
*.db
*.sqlite

# Dev/test files
*.test.*
*.spec.*
coverage

# Editor / OS
.vscode
.idea
.DS_Store

# Env files – inject at runtime via env vars
.env*
!.env.example

# Logs
*.log
